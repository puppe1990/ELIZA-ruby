#!/usr/bin/env ruby
# frozen_string_literal: true

require_relative "../lib/eliza"

locale = (ARGV[0] || "en").to_sym
bot = Eliza::Bot.default(locale: locale)

puts(bot.script.greeting)

loop do
  print("> ")
  input = $stdin.gets
  break if input.nil?

  input = input.strip
  break if input.empty?

  puts(bot.reply(input))
end
